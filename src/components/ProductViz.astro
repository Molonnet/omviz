---
const images = [
  { src: '/images/product/office-01.jpg', alt: 'Halyk CEO Office', title: 'CEO Office', label: 'Halyk Bank' },
  { src: '/images/product/office-02.jpg', alt: 'B1NK Meeting Room', title: 'Meeting Room', label: 'B1NK' },
  { src: '/images/product/office-03.jpg', alt: 'Kaskad Office', title: 'Open Office', label: 'Kaskad' },
];
---

<section class="product" id="product">
  <div class="product__inner">
    <h2 class="product__title">Product Visualization</h2>
    <div class="product__intro">
      <p>
        I produced high-quality 3D visualizations of products and objects
        for commercial and promotional use. My work included precise
        modeling and detailed rendering, with careful attention to form,
        texture, and context. I handled full production, including rendering in
        V-Ray and Corona and post-production of final imagery, with a focus
        on clarity, photorealism, and brand consistency.
      </p>
    </div>
    <p class="product__subtitle">Objects &amp; Details</p>

    <div class="product__grid">
      {images.map((img) => (
        <div class="product__item">
          <div class="product__image">
            <img src={img.src} alt={img.alt} loading="lazy" />
          </div>
          <h4 class="product__item-title">{img.title}</h4>
          <p class="product__item-label">{img.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .product {
    padding: 6rem 2rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .product__title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 400;
    text-align: center;
    margin-bottom: 3rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .product__intro {
    max-width: 520px;
    margin-bottom: 2rem;
  }

  .product__intro p {
    font-size: 0.85rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .product__subtitle {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .product__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .product__item {
    text-align: left;
  }

  .product__image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 2px;
    background: #f5f5f5;
    margin-bottom: 1rem;
  }

  .product__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .product__image:hover img {
    transform: scale(1.04);
  }

  .product__item-title {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .product__item-label {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .product {
      padding: 4rem 1.5rem;
    }

    .product__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
