  /* PARAGRAPH — высота управляется state-классами через max-height,
     потому что -webkit-line-clamp не транзишится плавно.

     line-height = 20px → 3 lines = 60px (default), 2 lines = 40px (scrolled),
     expanded = большое значение (1000px), чтобы фактический контент
     уместился — реальная высота схлопнется по тексту. */
  .archviz-modal-m__paragraph {
    font-family: var(--typography-body-font-family);
    font-weight: var(--typography-body-font-weight-medium);
    font-size: var(--typography-body-font-size);
    line-height: var(--typography-body-line-height);          /* 20 */
    letter-spacing: var(--typography-body-letter-spacing-tight);
    color: var(--color-content-foreground-base);
    /* pre-line — newlines из cat.body.join('\n\n') рендерятся как разрывы
       строк (пустая строка между абзацами), но пробелы по-прежнему
       нормализуются. Это позволяет -webkit-line-clamp работать поверх
       всего блока: clamp считает абсолютные строки, новые строки от
       \n считаются полноценными wrap-points. */
    white-space: pre-line;
    /* line-clamp для ellipsis (...) */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    /* max-height для плавного collapse */
    max-height: 60px;                                          /* 3 строки */
    transition: max-height 400ms ease;
