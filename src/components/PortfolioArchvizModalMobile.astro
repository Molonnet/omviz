  .archviz-modal-m__header {
    position: sticky;
    top: 60px;
    z-index: 2;
    background: var(--color-surface-base);
    display: flex;
    flex-direction: column;
    gap: var(--gap-2xl);                            /* 40 между Tabs и Intro */
    /* Padding-bottom добавляет немного воздуха перед карточками;
