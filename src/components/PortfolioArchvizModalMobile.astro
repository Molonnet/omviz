---
/* =============================================================
   PortfolioArchvizModalMobile — мобильная версия модалки-галереи
   для секции «Architectural Visualization».

   Источник: Figma node 1376:3325 (Gallery) + 1376:3277 (ImageViewer)
   Версия: redesign 2026-05-18 (см. baseline-commit 5e61915 для
   предыдущей реализации с табами/main/thumbs).

   КОНЦЕПТ:
   ─ Sticky header с Tabs + Intro (Title + Description + SEE MORE)
   ─ Под header — вертикальный СПИСОК всех картинок категории
     (карточка 358×198, gap 12). Никакого main image + thumbs.
   ─ Тап по карточке → открывается ImageViewer (тёмный оверлей
     поверх модалки), картинка свайпается влево/вправо.
   ─ Закрытие X в viewer → возвращает в галерею.
   ─ Закрытие X в галерее → закрывает всё.

   ПОВЕДЕНИЕ ПРИ СКРОЛЛЕ:
   Header sticky. Description имеет 3 состояния:
   1. default       → paragraph clamped 3 lines + "SEE MORE"
   2. expanded      → paragraph full (без clamp) + "SEE LESS"
   3. scrolled      → paragraph clamped 2 lines + "SEE MORE"
      (если был expanded, авто-сворачивается при первом скролле)

   ВЗАИМОИСКЛЮЧЕНИЕ:
   Mutually exclusive с PortfolioArchvizModal через @media
   на 1023.98/1024px — оба компонента смонтированы, видна одна.

   ВНЕШНИЙ КОНТРАКТ:
   [data-portfolio-open="<slug>"] — открывает галерею
   с активной категорией. Этот же контракт у десктопа.
   ============================================================= */

import { PORTFOLIO_CATEGORIES } from '../data/portfolio.ts';
import Button from './ui/Button.astro';
import Icon from './ui/Icon.astro';
import Tab from './ui/Tab.astro';

/* JSON для клиентского скрипта. mobileName ?? name — короткое имя
   для табов на мобиле (см. portfolio.ts комментарий про два поля). */
const data = PORTFOLIO_CATEGORIES.map((c) => ({
  slug: c.slug,
  name: c.mobileName ?? c.name,
  heading: c.heading,
  body: c.body,
  images: c.images,
}));
---

<div
  class="archviz-modal-m"
  data-archviz-modal-m
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-label="Portfolio gallery"
>
  {/* TOPBAR — sticky-полоса во всю ширину с фоном.
      Внутри Back-кнопка, выровнена влево. Полоса нужна, чтобы при
      скролле карточки не просвечивали через прозрачную область вокруг
      кнопки.

      Почему Back, а не X: эта модалка — fullscreen sheet (отдельный
      «экран в стеке»), а над ней может открыться lightbox со своим
      крестиком. Если оба слоя закрываются крестиком — пользователь
      путается, какой именно X что закроет. Конвенция iOS/Android:
      ←/Back = вернуться на предыдущий экран (стек), × = закрыть
      оверлей. Поэтому здесь Back слева (как «back» в нативной
      навигации), а X остаётся только у lightbox-а.

      Используем готовый <Button> из дизайн-системы — он уже знает
      про padding, типографику, фокусное кольцо и hover-цвета.
      Data-атрибут data-archviz-modal-m-close оставляем тот же:
      имя описывает действие (закрыть модалку), а не визуальный
      аффорданс — JS не нужно править. */}
  <div class="archviz-modal-m__topbar">
    <Button appearance="secondary" data-archviz-modal-m-close>
      <Icon name="arrow-left" />
      Back
    </Button>
  </div>

  <div class="archviz-modal-m__container">
    {/* HEADER — sticky под Close.
        Содержит Tabs + Intro. При прокрутке Intro paragraph
        re-clamps до 2 строк (см. state machine в скрипте). */}
    <header class="archviz-modal-m__header" data-archviz-modal-m-header>
      <div class="archviz-modal-m__tabs">
        <div class="archviz-modal-m__tabs-row" role="tablist">
          {data.map((cat) => (
            <Tab
              role="tab"
              data-archviz-modal-m-tab={cat.slug}
              aria-selected="false"
            >
              {cat.name}
            </Tab>
          ))}
        </div>
        <div class="archviz-modal-m__tabs-divider" aria-hidden="true"></div>
      </div>

      <div class="archviz-modal-m__intro">
        <h3 class="archviz-modal-m__title" data-archviz-modal-m-title></h3>
        <div class="archviz-modal-m__description">
          {/* Paragraph: высота управляется .is-expanded/.is-scrolled
              классами на корневой модалке. CSS transitions делают
              плавный collapse. */}
          <div class="archviz-modal-m__paragraph" data-archviz-modal-m-body></div>
          <button
            type="button"
            class="archviz-modal-m__see-more"
            data-archviz-modal-m-see-more
            aria-expanded="false"
          >
            <span data-archviz-modal-m-see-more-label>See more</span>
          </button>
        </div>
      </div>
    </header>

    {/* MEDIA — вертикальный список карточек.
        Перерендеривается при смене активной категории. */}
    <div class="archviz-modal-m__media" data-archviz-modal-m-media></div>
  </div>

  {/* IMAGE VIEWER — отдельный слой поверх галереи.
      Тёмный backdrop, картинка по центру (object-fit: contain),
      Close 44×44 справа сверху, счётчик "N/M" справа снизу.
      Свайп для навигации. */}
  <div
    class="archviz-modal-m__viewer"
    data-archviz-modal-m-viewer
    aria-hidden="true"
    role="dialog"
    aria-label="Image viewer"
  >
    <button
      type="button"
      class="archviz-modal-m__viewer-close"
      data-archviz-modal-m-viewer-close
      aria-label="Close image viewer"
    >
      <Icon name="close" />
    </button>
    {/* «Фрейм» картинки — <div> с background-image вместо <img>.
        Так избегаем багов <img>-state machine при быстрых сменах src:
        отменённые загрузки, race conditions при wrap-around (когда
        повторный URL не триггерит fresh fetch), коллапс в 0×0 пока
        intrinsic не декодирован. У div-а ничего этого нет — браузер
        просто рисует фон, когда сможет, размер div-а фиксирован CSS-ом
        и не зависит от состояния картинки. role="img" + aria-label
        в renderViewer держат семантику. */}
    <div
      class="archviz-modal-m__viewer-img"
      data-archviz-modal-m-viewer-img
      role="img"
      aria-label=""
    ></div>
    <p class="archviz-modal-m__viewer-counter" data-archviz-modal-m-viewer-counter>0/0</p>
  </div>

  <script type="application/json" data-archviz-modal-m-data set:html={JSON.stringify(data)}></script>
</div>

<script>
  /* ===========================================================
     Скрипт мобильной модалки.

     State (4 переменные):
       activeSlug   — какая категория активна (для рендера media)
       expanded     — пользователь нажал SEE MORE (paragraph full)
       scrolled     — пользователь проскроллил past threshold (60px)
       viewerIdx    — индекс картинки в viewer-е; -1 = viewer закрыт

     CSS-классы на root:
       .is-open       — модалка показана
       .is-expanded   — paragraph full (без clamp)
       .is-scrolled   — paragraph clamp до 2 строк (sticky compact)
       .is-viewer-open — viewer показан поверх

     Логика expanded/scrolled:
       - При первом скролле, если expanded → выключаем expanded
         (paragraph плавно сжимается обратно).
       - SEE MORE label меняется: scrolled || !expanded → "See more",
         else → "See less".
     =========================================================== */

  type Cat = { slug: string; name: string; heading: string; body: string[]; images: string[] };

  const root = document.querySelector<HTMLElement>('[data-archviz-modal-m]');
  if (root) {
    const dataNode = root.querySelector<HTMLScriptElement>('[data-archviz-modal-m-data]');
    const cats: Cat[] = dataNode ? JSON.parse(dataNode.textContent || '[]') : [];

    const titleEl   = root.querySelector<HTMLElement>('[data-archviz-modal-m-title]')!;
    const bodyEl    = root.querySelector<HTMLElement>('[data-archviz-modal-m-body]')!;
    const mediaEl   = root.querySelector<HTMLElement>('[data-archviz-modal-m-media]')!;
    const seeMore   = root.querySelector<HTMLButtonElement>('[data-archviz-modal-m-see-more]')!;
    const seeLabel  = root.querySelector<HTMLElement>('[data-archviz-modal-m-see-more-label]')!;
    const tabs      = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-archviz-modal-m-tab]'));

    /* Viewer-элементы.
       viewerImg — теперь <div>, а не <img>, см. комментарий в шаблоне.
       Тип HTMLElement, картинка задаётся через style.backgroundImage. */
    const viewer       = root.querySelector<HTMLElement>('[data-archviz-modal-m-viewer]')!;
    const viewerImg    = root.querySelector<HTMLElement>('[data-archviz-modal-m-viewer-img]')!;
    const viewerCount  = root.querySelector<HTMLElement>('[data-archviz-modal-m-viewer-counter]')!;

    let activeSlug = cats[0]?.slug ?? '';
    let expanded = false;
    let scrolled = false;
    let viewerIdx = -1;

    /* ---------- Helpers ---------- */

    function getCat(slug: string): Cat | undefined {
      return cats.find((c) => c.slug === slug);
    }

    function updateSeeMoreLabel() {
      /* SEE LESS только если развернут И не проскроллен.
         Во всех других кейсах — SEE MORE. */
      const showLess = expanded && !scrolled;
      seeLabel.textContent = showLess ? 'See less' : 'See more';
      seeMore.setAttribute('aria-expanded', String(showLess));
    }

    function applyStateClasses() {
      root!.classList.toggle('is-expanded', expanded && !scrolled);
      root!.classList.toggle('is-scrolled', scrolled);
      syncParagraphMaxHeight();
      updateSeeMoreLabel();
    }

    /* Управляем max-height paragraph-а через inline style.
       Почему так: CSS-овый .is-expanded { max-height: 1000px } не знает
       реальной высоты контента. Если body занимает, скажем, 180px, то
       обратный transition (1000 → 60) почти всё время держит max-height
       выше реальной высоты — box визуально не схлопывается до последних
       80мс. Хуже того, -webkit-line-clamp переключается мгновенно (3),
       но webkit-овая layout-машина в Safari иногда не пересчитывает
       рендер сразу, пока max-height транзишится сверху. Симптом — «See
       less не сворачивает текст».

       Решение: измерять реальный scrollHeight и ставить точный
       max-height inline. Inline побеждает CSS-токены, поэтому transition
       идёт между двумя «честными» значениями. */
    function syncParagraphMaxHeight() {
      if (expanded && !scrolled) {
        /* Класс is-expanded уже снял line-clamp (CSS .is-expanded даёт
           -webkit-line-clamp: 9999), поэтому scrollHeight отдаёт высоту
           всего контента. Ставим её как точный target. */
        bodyEl.style.maxHeight = bodyEl.scrollHeight + 'px';
      } else {
        /* Чистим inline, чтобы CSS снова взял управление:
           default = max-height 60px (3 строки),
           .is-scrolled = max-height 40px (2 строки).
           Браузер транзишит max-height от текущего inline-значения
           (например 180px) к CSS-овому 60px — плавно и до конца. */
        bodyEl.style.maxHeight = '';
      }
    }

    /* ---------- Gallery render ---------- */

    function renderGallery() {
      const cat = getCat(activeSlug);
      if (!cat) return;

      /* Tabs active state — aria-current="true" подсвечивает таб через
         CSS Tab-компонента (брендовый цвет). aria-selected оставляем
         для ARIA tablist-паттерна. См. подробный комментарий
         в PortfolioArchvizModal.astro. */
      tabs.forEach((t) => {
        const isActive = t.dataset.archvizModalMTab === activeSlug;
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        if (isActive) t.setAttribute('aria-current', 'true');
        else t.removeAttribute('aria-current');
      });

      /* Intro */
      titleEl.textContent = cat.heading;
      /* body — массив абзацев. Склеиваем \n\n; в CSS .archviz-modal-m__paragraph
         стоит white-space: pre-line, чтобы newlines стали разрывами строк.
         Это важнее, чем многократные <p>: -webkit-line-clamp работает только
         для одного flat-блока, а нам нужен общий 3-строчный clamp поверх
         всего описания. */
      bodyEl.textContent = cat.body.join('\n\n');

      /* Если у категории пустой body (все абзацы пустые) — прячем see more */
      const hasBody = cat.body.some((p) => p.trim().length > 0);
      seeMore.style.display = hasBody ? '' : 'none';

      /* Media: ребилд карточек.
         Используем innerHTML — самый компактный путь; для модалки
         с N=10-20 картинок это не bottleneck. */
      if (cat.images.length === 0) {
        mediaEl.innerHTML = '<p class="archviz-modal-m__empty">No images yet — drop files into public/images/archviz/' + cat.slug + '/</p>';
        return;
      }

      /* Карточки: ВАЖНО — НЕ ставим loading="lazy".
         Lazy ненадёжно работает внутри position:fixed scroll-container-а
         (модалка): IntersectionObserver может не триггерить загрузку для
         карточек ниже первого экрана → симптом «бесконечный loading +
         узкие серые полосы». Eager (default) грузит все сразу — у нас
         в категории ~15-30 jpg, это приемлемо.
         decoding="async" — декод не блокирует main thread.

         ВАЖНО: НЕ ставим width/height HTML-атрибутами.
         Браузер из них вычисляет aspect-ratio (358/198), который потом
         конфликтует с CSS height: 100% на узких viewport-ах (<390px):
         <img> рендерится МЕНЬШЕ карточки (например 290×160 вместо
         290×198), и серый фон карточки (--_color-neutral-100) виден
         рамкой со всех 4 сторон → визуально «потерянные скругления +
         задний фон». Layout-место уже резервирует сама карточка через
         height: 198px + min-height: 198px + flex-shrink: 0 — этого
         достаточно, чтобы при загрузке не было «узких полос». */
      mediaEl.innerHTML = cat.images.map((src, i) => `
        <button type="button" class="archviz-modal-m__card" data-archviz-modal-m-card="${i}" aria-label="Open image ${i + 1}">
          <img src="${src}" alt="${cat.name} — image ${i + 1}" decoding="async" />
        </button>
      `).join('');

      /* Сброс scroll к началу при смене категории — иначе пользователь
         оказывается посреди списка новой категории. */
      root!.scrollTop = 0;
      scrolled = false;
      expanded = false;
      applyStateClasses();
    }

    /* ---------- Open/close gallery ---------- */

    function openGallery(slug: string) {
      if (!getCat(slug)) return;
      activeSlug = slug;
      root!.setAttribute('aria-hidden', 'false');
      root!.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      renderGallery();
    }

    function closeGallery() {
      root!.setAttribute('aria-hidden', 'true');
      root!.classList.remove('is-open');
      document.body.style.overflow = '';
      /* На случай если viewer был открыт — закрываем тоже,
         чтобы при следующем openGallery начать с чистого состояния. */
      closeViewer();
    }

    /* ---------- See more toggle ---------- */

    seeMore.addEventListener('click', () => {
      if (scrolled) {
        /* В compact-режиме (после скролла) SEE MORE раскрывает текст
           И возвращает прокрутку наверх — иначе пользователь не увидит
           развёрнутый paragraph, он за пределами viewport. */
        root!.scrollTo({ top: 0, behavior: 'smooth' });
        /* expanded включится после того, как scroll listener
           обнулит scrolled. Делаем чуть-чуть с задержкой. */
        setTimeout(() => {
          expanded = true;
          applyStateClasses();
        }, 350);
      } else {
        expanded = !expanded;
        applyStateClasses();
      }
    });

    /* ---------- Scroll listener ---------- */

    /* Threshold: 60px. Меньше — слишком чувствительно, больше —
       долго ехать пока header станет компактным. */
    const SCROLL_THRESHOLD = 60;

    root.addEventListener('scroll', () => {
      const isScrolled = root!.scrollTop > SCROLL_THRESHOLD;
      if (isScrolled !== scrolled) {
        scrolled = isScrolled;
        /* Авто-сворачиваем expanded при скролле — пользователь должен
           снова нажать SEE MORE если хочет читать полный текст. */
        if (scrolled) expanded = false;
        applyStateClasses();
      }
    }, { passive: true });

    /* ---------- Image viewer ---------- */

    function openViewer(idx: number) {
      const cat = getCat(activeSlug);
      if (!cat || cat.images.length === 0) return;
      preloadCategory(cat);                          /* прогрев кэша */
      viewerIdx = Math.max(0, Math.min(idx, cat.images.length - 1));
      renderViewer();
      viewer.setAttribute('aria-hidden', 'false');
      viewer.classList.add('is-open');
      root!.classList.add('is-viewer-open');
    }

    function closeViewer() {
      if (viewerIdx === -1) return;
      viewerIdx = -1;
      viewer.setAttribute('aria-hidden', 'true');
      viewer.classList.remove('is-open');
      root!.classList.remove('is-viewer-open');
    }

    function renderViewer() {
      const cat = getCat(activeSlug);
      if (!cat || viewerIdx === -1) return;
      const src = cat.images[viewerIdx];
      /* CSS escape для url() — на случай если в имени файла будут
         кавычки/скобки. Сами картинки сейчас этого не содержат, но
         защита бесплатная. */
      const url = `url("${src.replace(/"/g, '\\"')}")`;

      /* Принудительный re-paint: сбрасываем bg → forced reflow → ставим
         новый url. Без этого браузер при wrap-around (последняя → первая)
         мог «оптимизировать» обновление и не перерисовывать слой, что
         давало баг «тёмный экран, counter меняется».
         offsetWidth — синхронный read, форсит layout flush между
         двумя style-присваиваниями. */
      viewerImg.style.backgroundImage = 'none';
      void viewerImg.offsetWidth;
      viewerImg.style.backgroundImage = url;

      viewerImg.setAttribute('aria-label', `${cat.name} — image ${viewerIdx + 1}`);
      viewerCount.textContent = `${viewerIdx + 1}/${cat.images.length}`;
    }

    /* Pre-warm кэш браузера: при openViewer заранее запрашиваем все
       картинки категории как фоновые Image()-объекты. К моменту
       свайпа они уже в memory cache — setting background-image
       рендерится мгновенно, без сетевых задержек. Защита от случаев,
       когда мобильный браузер под памятью эвиктит уже виденную
       картинку из кэша и при wrap-around нужно её снова грузить. */
    function preloadCategory(cat: Cat) {
      cat.images.forEach((src) => {
        const img = new Image();
        img.src = src;
      });
    }

    function viewerNext() {
      const cat = getCat(activeSlug);
      if (!cat || viewerIdx === -1) return;
      viewerIdx = (viewerIdx + 1) % cat.images.length;
      renderViewer();
    }

    function viewerPrev() {
      const cat = getCat(activeSlug);
      if (!cat || viewerIdx === -1) return;
      viewerIdx = (viewerIdx - 1 + cat.images.length) % cat.images.length;
      renderViewer();
    }

    /* ---------- Bindings ---------- */

    /* External trigger — open gallery */
    document.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement).closest<HTMLElement>('[data-portfolio-open]');
      if (trigger) {
        e.preventDefault();
        openGallery(trigger.dataset.portfolioOpen!);
      }
    });

    /* Close gallery */
    root.querySelector('[data-archviz-modal-m-close]')!.addEventListener('click', closeGallery);

    /* Tabs */
    tabs.forEach((t) => {
      t.addEventListener('click', () => {
        activeSlug = t.dataset.archvizModalMTab!;
        renderGallery();
      });
    });

    /* Card tap → open viewer */
    mediaEl.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest<HTMLElement>('[data-archviz-modal-m-card]');
      if (!card) return;
      openViewer(Number(card.dataset.archvizModalMCard));
    });

    /* Viewer close — кнопка X */
    viewer.querySelector('[data-archviz-modal-m-viewer-close]')!.addEventListener('click', closeViewer);

    /* Viewer close — тап по пустой зоне (backdrop) вокруг картинки.
       Логика: закрываем только если клик прилетел РОВНО в viewer
       (не в картинку, не в кнопку, не в счётчик). e.target — самый
       глубокий элемент под курсором; если это viewer — значит тапнули
       по пустоте. Свайп по картинке не сработает: click срабатывает
       только когда touchstart и touchend на одном элементе с малым
       смещением, а свайп смещает touchend → click не диспатчится. */
    viewer.addEventListener('click', (e) => {
      if (e.target === viewer) closeViewer();
    });

    /* Keyboard — ESC закрывает viewer, потом галерею.
       Стрелки переключают только если viewer открыт. */
    document.addEventListener('keydown', (e) => {
      if (root!.getAttribute('aria-hidden') === 'true') return;
      if (viewerIdx !== -1) {
        /* Viewer открыт — стрелки листают его */
        if (e.key === 'Escape') closeViewer();
        else if (e.key === 'ArrowRight') viewerNext();
        else if (e.key === 'ArrowLeft') viewerPrev();
      } else {
        /* Только галерея */
        if (e.key === 'Escape') closeGallery();
      }
    });

    /* Swipe в viewer-е.
       Threshold 40px, горизонтальное движение должно доминировать. */
    const SWIPE_THRESHOLD = 40;
    let touchStartX = 0;
    let touchStartY = 0;

    viewer.addEventListener('touchstart', (e) => {
      const t = e.changedTouches[0];
      touchStartX = t.clientX;
      touchStartY = t.clientY;
    }, { passive: true });

    viewer.addEventListener('touchend', (e) => {
      if (viewerIdx === -1) return;
      const t = e.changedTouches[0];
      const dx = t.clientX - touchStartX;
      const dy = t.clientY - touchStartY;
      if (Math.abs(dx) < SWIPE_THRESHOLD) return;
      if (Math.abs(dx) < Math.abs(dy)) return;
      if (dx < 0) viewerNext();
      else viewerPrev();
    }, { passive: true });
  }
</script>

<style>
  /* ============== ROOT ==============
     Fullscreen-модалка. Сама же scroll container — header будет
     sticky внутри неё. На десктопе скрыта через @media. */
  .archviz-modal-m {
    position: fixed;
    inset: 0;
    z-index: 100;
