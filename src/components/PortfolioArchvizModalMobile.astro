    flex-direction: column;
    gap: var(--gap-2xl);                            /* 40 между Header и Media */
  }

  /* ============== HEADER (sticky) ==============
     top: 60px — ровно под Topbar с Back-кнопкой.
     ВАЖНО: значение должно совпадать с .archviz-modal-m__topbar height.
     Если поменяешь высоту topbar — поменяй и это число.
