---
/* =============================================================
   Footer — финальная секция страницы.
   Источник: Figma node 292:1319 (instance "Footer")

   Структура (по Figma):
   ┌─ footer (flex column, gap 40px, items-center, surface/base bg)
   │  ├─ Divider top (1px, full-width)
   │  ├─ container (1196px × 192px, 8-col grid, gap-x 20px)
   │  │  ├─ Logo          col 1-2
   │  │  ├─ ContactColumn col 3-4 (Email / Phone / Location — gap-y 24px)
   │  │  ├─ NavColumn     col 5   (5 footer-ссылок, gap-y 4px)
   │  │  └─ MetaColumn    col 7   (flex column, justify-between)
   │  │     ├─ LinkColumn        (Cookies / Privacy / Terms)
   │  │     └─ Button primary    ("Let's connect" → ContactModal)
   │  └─ Divider bottom (1px, full-width)

   Внешние отступы:
     Нет padding-y у самого <footer>. Вертикальные 40px-отступы
     даются gap-ом между divider'ами и container'ом. Это точно
     повторяет Figma.

   Container height: 278px — фиксированная, чтобы justify-between
   у MetaColumn реально разнёс LinkColumn и Button по верху/низу.
   Без фиксированной высоты flex-колонка схлопнулась бы по контенту
   и Button прижался бы к ссылкам.

   "Let's connect":
     Использует тот же Button.primary, что и кнопка в Hero ("See
     Portfolio"). В Figma — это primary-цвет (#a044ca), text-only.
     Триггер модалки — атрибут data-contact-open (тот же, что
     в Header). Один глобальный listener в ContactModal.astro
     обрабатывает клик из любого места сайта.
   ============================================================= */

import Logo from './Logo.astro';
import Link from './ui/Link.astro';
import NavLink from './ui/NavLink.astro';
import ContactItem from './ui/ContactItem.astro';
import Button from './ui/Button.astro';
import Icon from './ui/Icon.astro';
import { navLinks } from '../data/navLinks';

/* Мета-ссылки (Cookies / Privacy / Terms) — пока заглушки.
   Когда будут реальные страницы — поменяем href. */
const metaLinks = [
  { label: 'Cookies',            href: '#cookies' },
  { label: 'Privacy policy',     href: '#privacy' },
  { label: 'Terms & Conditions', href: '#terms' },
];

/* Контакты — owner-data. Email и Phone делаются ссылками
   (mailto: / tel:), Location — просто текст. */
const contacts = [
  { overline: 'Email',    value: 'molviz.ny@gmail.com', href: 'mailto:molviz.ny@gmail.com', copyable: true },
  { overline: 'Phone',    value: '646-853-7036',        href: 'tel:+16468537036',          copyable: true },
  { overline: 'Location', value: 'Sunnyvale, CA',       href: undefined,                   copyable: false },
];
---

<footer class="site-footer">
  {/* Верхний divider — отделяет футер от последней секции страницы.
      muted-цвет (#B8B8B8), 1px высота. */}
  <hr class="site-footer__divider" />

  <div class="site-footer__container">
    {/* Колонка 1-2: логотип. Тот же <Logo /> что в шапке —
        единый идентичный знак, не другой размер/шрифт. */}
    <div class="site-footer__logo">
      <Logo />
    </div>

    {/* Колонка 3-4: контакты. Email/Phone — кликабельны, hover-копи-кнопка.
        Location — просто текст без copy (адрес копировать незачем). */}
    <div class="site-footer__contacts">
      {contacts.map((c) => (
        <ContactItem
          overline={c.overline}
          value={c.value}
          href={c.href}
          copyable={c.copyable}
        />
      ))}
    </div>

    {/* Колонка 5: дублирует главную навигацию.
        Источник — src/data/navLinks.ts (общий для Header и Footer).
        Используем <NavLink size="sm">, а не <Link>: это НАВИГАЦИЯ
        (а не контентная ссылка), поэтому visited тут семантически
        не нужен. У NavLink нет :visited — ссылки не позеленеют
        фиолетовым после первого клика. */}
    <nav class="site-footer__nav" aria-label="Footer navigation">
      {navLinks.map((link) => (
        <NavLink href={link.href} size="sm">{link.label}</NavLink>
      ))}
    </nav>

    {/* Колонка 7: meta-блок.
        Сверху — мелкие политики, снизу — accent-кнопка "Let's connect".
        justify-between разносит их по высоте 278px контейнера. */}
    <div class="site-footer__meta">
      <div class="site-footer__meta-links">
        {metaLinks.map((link) => (
          <Link href={link.href}>{link.label}</Link>
        ))}
      </div>

      <Button appearance="primary" data-contact-open>
        Let’s connect
        <Icon name="chat-conversation-circle" />
      </Button>
    </div>
  </div>

  {/* Нижний divider — закрывает футер снизу.
      Тот же muted-цвет, та же full-width-ширина. */}
  <hr class="site-footer__divider" />
</footer>

<style>
  .site-footer {
    background: var(--color-surface-base);
    /* Вертикальная ось: divider — 40px — container — 40px — divider.
       align-items: center чтобы container 1196px центрировался. */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-2xl);                   /* 40px */
  }

  /* MOBILE — десктопный футер скрывается, его место занимает
     <FooterMobile />. Граница 1023.98 / 1024px синхронизирована
     с tokens.css и остальными mobile/desktop парами. */
  @media (max-width: 1023.98px) {
    .site-footer {
      display: none;
    }
  }

  .site-footer__divider {
    border: none;
    height: 1px;
    width: 100%;
    background: var(--color-content-foreground-muted);
    margin: 0;
  }

  .site-footer__container {
    width: 1196px;
    max-width: 100%;
    margin: 0 auto;
    padding: 0 var(--gap-md);
    /* Фиксированная высота 192px по Figma (h-192 на слое Container).
       Критична для justify-between внутри MetaColumn: без неё колонка
       схлопнется по контенту, и Button прижмётся к LinkColumn вплотную.
       С h-192 MetaColumn fill (= align-self: stretch) растягивается
       на полную высоту, и justify-between корректно разносит
       LinkColumn (верх) и Button «Let's connect» (низ). */
    height: 192px;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    column-gap: var(--gap-lg);             /* 20px между колонками */
  }

  /* ============== COL 1-2 / LOGO ============== */
  .site-footer__logo {
    grid-column: 1 / span 2;
    align-self: start;                     /* по верху, как Contact/Nav */
    display: flex;
    align-items: center;
  }

  /* ============== COL 3-4 / CONTACTS ============== */
  .site-footer__contacts {
    grid-column: 3 / span 2;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: var(--gap-xl);                    /* 24px между ContactItem */
  }

  /* ============== COL 5 / NAV ==============
     5 footer-ссылок. gap-2xs = 4px между ними — плюс padding-y
     самого <NavLink size="sm"> (4px) даёт визуальный ритм 4+4+4 = 12px
     между базовыми линиями текста соседних ссылок. */
  .site-footer__nav {
    grid-column: 5 / span 1;
    align-self: start;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--gap-2xs);                   /* 4px */
  }

  /* ============== COL 7 / META ==============
     stretch — тянем колонку на полную высоту 278px,
     justify-between — прижимаем ссылки к верху, кнопку к низу. */
  .site-footer__meta {
    grid-column: 7 / span 1;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
  }

  .site-footer__meta-links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--gap-2xs);                   /* 4px — как у nav-колонки */
  }
</style>
