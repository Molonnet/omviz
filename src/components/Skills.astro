---
const professionalSkills = [
  '3D Studio Max',
  'Advanced 3D modeling skills (high/low poly)',
  'V-Ray, Corona rendering',
  'Texturing, material creation',
  'UV/W mapping and proper texture placement',
  'Working with AutoCAD and integrating to 3D Studio Max',
  'Understanding of architectural/CG standards',
  'Adobe After Effects for compositing and basic animation',
  'Adobe Illustrator and vector graphics',
  'Using AI tools for idea generation',
];

const personalStrengths = [
  'Talented and passionate, consistently striving for excellence',
  'Strong composition and color sense',
  'Detail-oriented and resourceful in problem-solving',
  'Self-motivated fast learner with excellent time management',
  'Collaborative team player',
  'Skilled in managing multiple tasks and projects simultaneously',
  'Strong interest in the latest digital trends',
  'Quick learner, adaptable to new tools and technologies',
  'Authorized to work in the U.S.',
];

const previewImages = [
  { src: '/images/archviz/public-01.jpg', alt: 'B1NK Banking Hall' },
  { src: '/images/archviz/residential-01.jpg', alt: 'City Apartment Living Room' },
  { src: '/images/product/office-01.jpg', alt: 'CEO Office' },
  { src: '/images/archviz/exterior-01.jpg', alt: 'Building Exterior' },
];
---

<section class="skills">
  <div class="skills__inner">
    <div class="skills__grid">
      <div class="skills__column">
        <h3 class="skills__heading">Professional Competencies</h3>
        <ul class="skills__list">
          {professionalSkills.map((skill) => (
            <li>{skill}</li>
          ))}
        </ul>
      </div>
      <div class="skills__column">
        <h3 class="skills__heading">Personal Strengths</h3>
        <ul class="skills__list">
          {personalStrengths.map((skill) => (
            <li>{skill}</li>
          ))}
        </ul>
      </div>
    </div>
    <div class="skills__preview">
      {previewImages.map((img) => (
        <div class="skills__preview-item">
          <img src={img.src} alt={img.alt} loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills {
    padding: 2rem 2rem 4rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .skills__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    padding: 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    margin-bottom: 3rem;
  }

  .skills__heading {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: 1.2rem;
  }

  .skills__list {
    list-style: none;
    font-size: 0.85rem;
    line-height: 1.9;
    color: var(--color-text);
  }

  .skills__preview {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .skills__preview-item {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 2px;
    background: #f5f5f5;
  }

  .skills__preview-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .skills__preview-item:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .skills__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 1.5rem;
    }

    .skills__preview {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }
</style>
