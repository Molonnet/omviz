---
/* =============================================================
   PortfolioSectionMobile — мобильная версия секции
   «Architectural Visualization».
   Источник: Figma node 1355:2678 (frame "PortfolioSection" / mobile)

   Структура (по Figma):
   ┌─ section (surface-base, py 40, px 16, gap 32 col, items-start)
   │  ├─ Content (flex col, gap 24, w-full)
   │  │  ├─ Heading «architectural visualization» (heading/medium, w-full)
   │  │  └─ Sub-content (flex col, gap 20, pl 92, w-full)
   │  │     ├─ Body (Roboto Medium 16/20, -0.8 letter-spacing,
   │  │     │       многоабзацный текст)
   │  │     └─ Link «Read more» (label/2xs/medium 14/16, py 8)
   │  └─ ImageColumn (flex col, gap 12, w-full)
   │     └─ 4× cover-тайл (h 198, radius-sm, object-cover, w-full)
   │        каждый — <button>, открывает PortfolioArchvizModal с slug-ом

   Чем отличается от десктопа:
   ─ Текст и тайлы — одна вертикальная стопка (на десктопе — текст вверху,
     ниже сложный absolute-коллаж из 4 разных размеров).
   ─ На мобиле все 4 тайла одинаковые (198px высота, full-width), порядок
     по PORTFOLIO_CATEGORIES.slice(0, 4) — тот же, что на десктопе.
   ─ Sub-content имеет pl 92 — повторяет художественный приём из Hero
     и About: текст начинается со "второй направляющей", создаёт ритм.

   Контракт триггера модалки тот же:
     data-portfolio-open="<slug>" + slug в data/portfolio.ts
   ============================================================= */

import { PORTFOLIO_CATEGORIES, ARCHVIZ_INTRO } from '../data/portfolio.ts';

/* Берём первые 4 категории — те же, что на десктопе в коллаже.
   Если когда-нибудь категорий станет больше — менять PORTFOLIO_CATEGORIES,
   а тут просто slice(0, N) с тем же N. */
const tiles = PORTFOLIO_CATEGORIES.slice(0, 4);
---

<section class="portfolio-m">
  <div class="portfolio-m__content">
    <h2 class="portfolio-m__heading">{ARCHVIZ_INTRO.heading}</h2>
    <div class="portfolio-m__sub">
      <div class="portfolio-m__body">
        {ARCHVIZ_INTRO.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </div>

  <div class="portfolio-m__images">
    {tiles.map((tile) => (
      <button
        type="button"
        class="portfolio-m__tile"
        data-portfolio-open={tile.slug}
        aria-label={`Open ${tile.name} gallery`}
      >
        {tile.cover ? (
          <img src={tile.cover} alt={tile.name} loading="lazy" />
        ) : (
          <span class="portfolio-m__placeholder">{tile.name}</span>
        )}
      </button>
    ))}
  </div>
</section>

<style>
  /* ============== ROOT ============== */
  /* Mobile-only. На десктопе скрыт через @media ниже + десктопный
     PortfolioSection прячется через свой @media → mutually exclusive. */
  .portfolio-m {
    background: var(--color-surface-base);
    /* По Figma: py = 40 (--padding-2xl), px = 16 (--gap-md, токена
       padding-base пока нет в шкале — приём как в Hero/About mobile).
       gap 32 между Content и ImageColumn — в gap-токенах нет такого
       значения (gap-xl=24, gap-2xl=40, gap-3xl=50). Берём литерал
       с комментарием — прецедент уже есть в десктопном PortfolioSection
       (там gap: 60px тоже литерал). */
    padding: var(--padding-2xl) var(--gap-md);
    display: flex;
    flex-direction: column;
    gap: 32px;                              /* нет токена ровно на 32 */
    align-items: flex-start;
  }
  @media (min-width: 1024px) {
    .portfolio-m {
      display: none;
    }
  }

  /* ============== CONTENT (Heading + Sub) ============== */
  .portfolio-m__content {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--gap-xl);                     /* 24 между заголовком и sub */
  }

  /* Heading — тот же heading-токен, что на десктопе.
     Anybody Medium 36/36, capslock (text-transform), color base.
     На мобиле tokens.css не переопределяет heading-size, остаётся 36/36. */
  .portfolio-m__heading {
    margin: 0;
    font-family: var(--typography-heading-font-family);
    font-weight: var(--typography-heading-font-weight);
    font-size: var(--typography-heading-font-size);
    line-height: var(--typography-heading-line-height);
    letter-spacing: var(--typography-heading-letter-spacing);
    color: var(--color-content-foreground-base);
    text-transform: uppercase;
    /* По Figma word-break: break-word — длинное "VISUALIZATION" не
       должно вытеснять контейнер; на 390px шириной без break-word
       слово вылезает за края при padding 16. */
    word-break: break-word;
  }

  /* Sub-content — body + link, оба сдвинуты вправо на pl 92.
     92 — арт-выбор (та же "вторая направляющая", что в Hero/About);
     это не совпадение с шириной ленты About (тоже 92 = 80+12),
     но визуально создаёт единый ритм отступов через всю мобилу. */
  .portfolio-m__sub {
    width: 100%;
    padding-left: 92px;
    display: flex;
    flex-direction: column;
    gap: var(--gap-lg);                     /* 20 между body и link */
  }

  /* ============== BODY ============== */
  .portfolio-m__body {
    font-family: var(--typography-body-font-family);
    font-weight: var(--typography-body-font-weight-medium);
    font-size: var(--typography-body-font-size);            /* 16 */
    line-height: var(--typography-body-line-height);        /* 20 */
    letter-spacing: var(--typography-body-letter-spacing-tight); /* -0.8 */
    color: var(--color-content-foreground-base);
  }
  .portfolio-m__body p {
    margin: 0;
    /* см. десктоп: избегаем «сирот» на последней строке */
    text-wrap: pretty;
  }
  /* Между смысловыми абзацами — пустая строка ровно в одну высоту body
     line-height. То же правило, что в десктопе. */
  .portfolio-m__body p + p {
    margin-top: var(--typography-body-line-height);
  }

  /* (Раньше тут была .portfolio-m__readmore — кнопка «Read more».
     Удалена вместе с десктопной; интро теперь без CTA.) */

  /* ============== IMAGE COLUMN ============== */
  .portfolio-m__images {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);                     /* 12 между тайлами */
  }

  /* Тайл — <button> вместо <a>, потому что открывается модалка
     (а не переход по URL). Тот же контракт, что на десктопе:
     data-portfolio-open="<slug>" слушает PortfolioArchvizModal.
     По Figma: h 198, radius-sm, w 100%, content overflow-clip. */
  .portfolio-m__tile {
    width: 100%;
    height: 198px;
    padding: 0;
    border: none;
    background: var(--_color-neutral-100);  /* фолбэк, если cover не загрузился */
    border-radius: var(--radius-sm);        /* 12 */
    overflow: hidden;
    cursor: pointer;
    display: block;
    /* Лёгкий tap-feedback на мобиле — тот же приём, что на десктопе,
       но без hover (он на тач-устройствах не работает). На active
       немного приглушаем — обратная связь, что клик зарегистрирован. */
    transition: transform 200ms ease;
  }
  .portfolio-m__tile:active {
    transform: scale(0.99);
  }
  .portfolio-m__tile:focus-visible {
    outline: 2px solid var(--color-focus-ring-default);
    outline-offset: 4px;
  }

  .portfolio-m__tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Плейсхолдер для категории без обложки (cover === null).
     Показывает имя категории по центру тайла. */
  .portfolio-m__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-content-foreground-muted);
    font-family: var(--typography-body-font-family);
    font-size: var(--typography-body-font-size);
  }
</style>
