---
/* =============================================================
   Logo — текстовый логотип «Olga Malysheva».
   Источник: Figma node 246:671 (component "Logo")

   Шрифт — Satisfy, через токены --typography-logo-*.
   Эти токены живут отдельным блоком LOGO в tokens.css, не среди
   общих ролей: бренд-знак, не переиспользуемая роль.
   Сам файл шрифта подключён через Google Fonts в Layout.astro.

   Цвет: action.foreground.secondary.default — как у NavLink,
   логотип ведёт себя как кликабельная ссылка на /.
   ============================================================= */

interface Props {
  /** Куда ведёт клик по логотипу. По умолчанию домой. */
  href?: string;
}

const { href = '/' } = Astro.props;
---

<a href={href} class="logo" aria-label="Olga Malysheva — homepage">
  Olga Malysheva
</a>

<style>
  .logo {
    font-family: var(--typography-logo-font-family);
    font-weight: var(--typography-logo-font-weight);
    font-size: var(--typography-logo-font-size);
    line-height: var(--typography-logo-line-height);
    letter-spacing: var(--typography-logo-letter-spacing);
    color: var(--color-action-foreground-secondary-default);
    text-decoration: none;
    transition: color 120ms ease;
  }

  .logo:hover {
    color: var(--color-action-foreground-secondary-hover);
  }

  .logo:focus-visible {
    outline: 2px solid var(--color-focus-ring-default);
    outline-offset: 2px;
    border-radius: var(--radius-xs);
  }
</style>
