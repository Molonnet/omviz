---
/* =============================================================
   TextField — design-system primitive
   Источник: Figma node 544:3668 (component set "TextField")
   Обновлено по правкам 2026-05-12.

   Варианты (из Figma):
     State × Content
     - State: Default | Hover | Focus | Error | Disabled
     - Content: Empty | Filled
       (определяется автоматически через :placeholder-shown)

   Анатомия (по новой Figma):
   ┌─ <div> root (column, gap-2xs если есть helper)
   │  ├─ Field (rounded-sm, padding 12 со всех сторон, bg/border по state)
   │  │  └─ Content (column, h-34, justify-center)
   │  │     ├─ LabelRow: label-text + required "*"
   │  │     └─ InputArea (placeholder + caret + value)
   │  └─ Helper (caption, padding-x 12, muted/error)

   Поведение лейбла (Material-style floating):
     - Empty & not-focused → label 16px (label/sm), центрирован в 34px Content
       (input визуально схлопывается, чтоб всё помещалось)
     - Focused или Filled → label 12px (label/3xs) сверху, под ним input/placeholder

   Placeholder:
     - Скрыт когда поле не в фокусе (его роль играет большой label)
     - Виден когда фокус и поле пустое

   Clear-button:
     - 24×24 ButtonIcon справа, иконка close
     - Видна только когда поле в фокусе И в нём есть значение
       (CSS-условие: :focus-within + :has(.tf__input:not(:placeholder-shown)))
     - tabindex=-1 — выпадает из tab-порядка (UX как в Material; чтобы
       не сбивать фокус-флоу при выходе из инпута)
     - mousedown → preventDefault, чтобы input не успел потерять фокус
       до того, как мы обработаем клик (иначе кнопка скрывается раньше
       срабатывания click-а)
     ============================================================= */

import Icon from './Icon.astro';

interface Props {
  /** name атрибута формы */
  name: string;
  /** Текст лейбла */
  label: string;
  /** type инпута, по умолчанию 'text' */
  type?: 'text' | 'email' | 'tel' | 'url' | 'password' | 'number';
  /** Placeholder, виден только когда поле в фокусе и пустое */
  placeholder?: string;
  /** Подсказка/ошибка под полем */
  helper?: string;
  /** Required → красная * + native required */
  required?: boolean;
  /** Error-стиль */
  error?: boolean;
  /** Disabled state */
  disabled?: boolean;
  /** Рендерить ли кнопку очистки. По умолчанию true. */
  clearable?: boolean;
  /** id для связки label↔input */
  id?: string;
  /** Любые data-* / aria-* / native атрибуты пробрасываются на <input> */
  [key: string]: unknown;
}

const {
  name,
  label,
  type = 'text',
  placeholder = ' ',
  helper,
  required = false,
  error = false,
  disabled = false,
  clearable = true,
  id,
  ...rest
} = Astro.props;

const inputId = id ?? `tf-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class:list={['tf', { 'tf--error': error, 'tf--disabled': disabled }]}
  data-textfield
>
  <div class="tf__field">
    <div class="tf__content">
      <label class="tf__label" for={inputId}>
        <span class="tf__label-text">{label}</span>
        {required && <span class="tf__required" aria-hidden="true">*</span>}
      </label>
      <input
        id={inputId}
        name={name}
        type={type}
        required={required}
        disabled={disabled}
        aria-invalid={error ? 'true' : undefined}
        aria-describedby={helper ? `${inputId}-helper` : undefined}
        placeholder={placeholder}
        class="tf__input"
        {...rest}
      />
    </div>
    {clearable && !disabled && (
      <button
        type="button"
        class="tf__clear"
        data-textfield-clear
        tabindex="-1"
        aria-label="Clear field"
      >
        <Icon name="close" />
      </button>
    )}
  </div>
  {helper && (
    <p id={`${inputId}-helper`} class="tf__helper">{helper}</p>
  )}
</div>

<script>
  /* ===========================================================
     Clear-button handler.
     Делегат на весь документ — один listener обслуживает все
     инстансы TextField на странице (Astro дедуплицирует <script>).

     Почему mousedown, а не click:
     - click срабатывает по последовательности mousedown → mouseup →
       blur (если клик вне input-а) → click.
     - На blur input теряет фокус → :focus-within у .tf__field
       становится false → .tf__clear получает opacity:0,
       pointer-events:none → click до неё уже не доходит.
     - Перехватив на mousedown + preventDefault, мы блокируем blur
       у input-а: фокус остаётся внутри, кнопка остаётся видимой,
       и можно безопасно очистить value.
     =========================================================== */

  document.addEventListener('mousedown', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-textfield-clear]');
    if (!btn) return;

    /* preventDefault на mousedown = не давать input-у потерять фокус.
       stopPropagation страхует от внешних делегатов (например,
       [data-contact-open] на родителе модалки). */
    e.preventDefault();
    e.stopPropagation();

    const root = btn.closest<HTMLElement>('[data-textfield]');
    if (!root) return;
    const input = root.querySelector<HTMLInputElement>('.tf__input');
    if (!input) return;

    input.value = '';

    /* Диспатчим bubbling 'input' event — чтобы внешние слушатели
       (например, syncSubmit() в ContactModal) пересчитали validity
       и обновили disabled-стейт submit-кнопки. */
    input.dispatchEvent(new Event('input', { bubbles: true }));

    /* Фокус явно возвращаем в input — на случай если браузер всё-таки
       снял его (Safari иногда игнорирует preventDefault на mousedown
       для button-элементов). */
    input.focus();
  });
</script>

<style>
  /* ============== ROOT ============== */
  .tf {
    display: flex;
    flex-direction: column;
    gap: var(--gap-2xs);                /* 4px между field и helper */
    width: 100%;
  }

  /* ============== FIELD ==============
     По новой Figma: padding 12px со всех сторон (--padding-lg).
     Border 1px solid transparent в default — резервирует место,
     чтобы hover/focus/error не сдвигали layout. */
  .tf__field {
    display: flex;
    align-items: center;
    padding: var(--padding-lg);          /* 12px все стороны */
    border-radius: var(--radius-sm);     /* 12px */
    background: var(--color-form-background-base-default);
    border: 1px solid var(--color-form-border-base-default);  /* transparent */
    transition: background-color 120ms ease, border-color 120ms ease;
  }

  /* HOVER (не в error/disabled) */
  .tf:not(.tf--error):not(.tf--disabled) .tf__field:hover {
    background: var(--color-form-background-base-hover);
    border-color: var(--color-form-border-base-hover);
  }
  /* FOCUS-WITHIN */
  .tf:not(.tf--error):not(.tf--disabled) .tf__field:focus-within {
    background: var(--color-form-background-base-focus);
    border-color: var(--color-form-border-accent-focus);
  }
  /* ERROR */
  .tf--error .tf__field {
    background: var(--color-form-background-base-error);
    border-color: var(--color-form-border-base-error);
  }
  /* DISABLED */
  .tf--disabled .tf__field {
    background: var(--color-form-background-base-disabled);
    cursor: not-allowed;
  }

  /* ============== CONTENT ==============
     Высота ЖЁСТКАЯ 34px (а не min-height), и вот почему:

     При потере фокуса на пустом поле одновременно стартуют две
     transition-анимации:
       - .tf__input: height 20px → 0
       - .tf__label: font-size 12→16, line-height 14→20
     Сумма детей меняется 34 → 20 за 120ms. С min-height 34 контейнер
     номинально остаётся 34, но во время transition браузер каждый
     кадр пересчитывает flex-layout — и реальная высота слегка
     "дышит" на subpixel-уровне. Из-за того, что модалка в
     overflow-y:auto центрируется через `margin: auto 0`, даже
     эта микро-рябь визуально читается как "подпрыгивание" всей
     секции при потере фокуса.

     Жёсткий height (вместо min-height) делает контейнер rigid:
     любые внутренние transition-ы изолированы и наружу не выходят. */
  .tf__content {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
    height: 34px;
  }

  /* ============== LABEL ============== */
  .tf__label {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
    font-family: var(--typography-label-font-family);
    font-weight: var(--typography-label-font-weight-regular);
    color: var(--color-content-foreground-base);
    /* Дефолт = маленький лейбл (filled/focus стейт).
       Транзишн между empty (16px) и filled (12px) плавный. */
    font-size: var(--typography-label-font-size-3xs);
    line-height: var(--typography-label-line-height-3xs);
    letter-spacing: var(--typography-label-letter-spacing-normal);
    cursor: text;
    transition: font-size 120ms ease, line-height 120ms ease;
  }
  /* Empty & not-focused: лейбл «раздувается» обратно до 16px и работает как placeholder */
  .tf__field:has(.tf__input:placeholder-shown:not(:focus)) .tf__label-text {
    font-size: var(--typography-label-font-size-sm);
    line-height: var(--typography-label-line-height-sm);
    letter-spacing: var(--typography-label-letter-spacing-snug);
  }
  /* Required `*` — всегда 12px */
  .tf__required {
    margin-left: 1px;
    font-size: var(--typography-label-font-size-3xs);
    line-height: var(--typography-label-line-height-3xs);
    color: var(--color-content-foreground-base-error);
  }
  .tf--disabled .tf__label {
    color: var(--color-content-foreground-muted);
    cursor: not-allowed;
  }

  /* ============== INPUT ==============
     В empty-state без фокуса input «коллапсирует» (height:0) — на его месте
     визуально остаётся только большой label, который центрируется
     в content min-h 34. Когда фокус приходит или появилось значение —
     input разворачивается на свою line-height. */
  .tf__input {
    width: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-content-foreground-strong);
    font-family: var(--typography-body-font-family);
    font-weight: var(--typography-body-font-weight-regular);
    font-size: var(--typography-body-font-size);
    line-height: var(--typography-body-line-height);
    letter-spacing: var(--typography-body-letter-spacing-snug);
    outline: none;
    caret-color: var(--color-form-border-accent-focus);
    /* По умолчанию виден на свою высоту */
    height: var(--typography-body-line-height);  /* 20px */
    overflow: hidden;
    transition: height 120ms ease;
  }
  /* Коллапс в empty+not-focused */
  .tf__field:has(.tf__input:placeholder-shown:not(:focus)) .tf__input {
    height: 0;
  }
  /* Placeholder: скрыт когда не в фокусе (большой label играет его роль),
     виден когда фокус */
  .tf__input::placeholder {
    color: var(--color-content-foreground-muted);
    opacity: 1;
  }
  .tf__field:not(:focus-within) .tf__input::placeholder {
    color: transparent;
  }
  .tf__input:disabled {
    color: var(--color-content-foreground-muted);
    -webkit-text-fill-color: var(--color-content-foreground-muted);
    cursor: not-allowed;
  }

  /* ============== CLEAR BUTTON ==============
     По Figma 544:3668: ButtonIcon 24×24 справа от content-а, иконка close.
     Видна только когда поле в фокусе И в нём есть значение.

     Логика visibility через :has() + :placeholder-shown:
     - :focus-within у .tf__field → поле в фокусе
     - :has(.tf__input:not(:placeholder-shown)) → в input-е есть value
       (placeholder-shown=true только когда value пустое, т.к.
       placeholder по умолчанию = ' ' — служебный single space)

     opacity, а не display — чтобы изменение visibility не вызывало
     reflow внутри .tf__field и не дёргало layout (соблюдаем тот же
     принцип rigid-контейнера, что и для .tf__content).

     pointer-events: none когда скрыта — иначе невидимая кнопка ловила
     бы клики в правой части поля и мешала бы попадать курсором в input. */
  .tf__clear {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    margin-left: var(--gap-sm);          /* 12px от content-а */
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-action-foreground-base-default);
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease, color 120ms ease, transform 80ms ease;
  }
  .tf__field:focus-within:has(.tf__input:not(:placeholder-shown)) .tf__clear {
    opacity: 1;
    pointer-events: auto;
  }
  .tf__clear:hover  { color: var(--color-action-foreground-base-hover); }
  .tf__clear:active {
    color: var(--color-action-foreground-base-press);
    transform: scale(0.92);
  }
  /* В error-state кнопка очистки красная — подсказка, что "очистить ошибочный ввод" */
  .tf--error .tf__clear { color: var(--color-content-foreground-base-error); }

  /* ============== HELPER ============== */
  .tf__helper {
    margin: 0;
    padding: 0 var(--padding-lg);
    font-family: var(--typography-caption-font-family);
    font-weight: var(--typography-caption-font-weight);
    font-size: var(--typography-caption-font-size);
    line-height: var(--typography-caption-line-height);
    letter-spacing: var(--typography-caption-letter-spacing);
    color: var(--color-content-foreground-muted);
  }
  .tf--error .tf__helper {
    color: var(--color-content-foreground-base-error);
  }
</style>
