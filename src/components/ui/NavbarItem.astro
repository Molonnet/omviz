---
/* =============================================================
   NavbarItem — design-system primitive
   Источник: Figma node 198:1313 (component "NavbarItem")

   Назначение: элемент навигационного меню (ссылка).
   Семантически — это <a>, а не <button>:
     <button> = «сделай действие»
     <a>      = «перейди в другое место» ← наш случай

   Состояния (из Figma):
     - State: default | hover | press | disabled
       (hover/press — pseudo-states, обрабатываются CSS)

   Стиль: text-only ссылка с горизонтальным padding для зоны клика.
   Цвета: только нейтральная шкала action.foreground.base.*

   Проверено по Figma 2026-05-01:
     - Typography: label / medium / md (18/24, Roboto, letter-spacing wide=0.15px)
     - Vertical padding: padding-md (8px)
     - Horizontal padding: padding-lg (12px) — отличие от Button (там 0)
     - Gap text↔icon: gap-2xs (4px)
     - Focus ring: 2px solid action/outline/focus, inset 0, radius/xs (4px)
     - Слот <Icon /> опционален (passing children)
   ============================================================= */

interface Props {
  /** Куда ведёт ссылка (URL или якорь) */
  href: string;
  /** Заблокированное состояние — у <a> нет нативного disabled,
      эмулируем через aria-disabled + CSS + tabindex */
  disabled?: boolean;
}

const {
  href,
  disabled = false,
} = Astro.props;
---

<a
  href={disabled ? undefined : href}
  aria-disabled={disabled ? 'true' : undefined}
  tabindex={disabled ? -1 : undefined}
  class="nav-item"
>
  <slot />
</a>

<style>
  .nav-item {
    /* layout — Figma:
       padding 8px по вертикали, 12px по горизонтали (зона клика),
       gap 4px между текстом и иконкой */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--gap-2xs);
    padding: var(--padding-md) var(--padding-lg);

    /* убираем дефолтный underline у <a> */
    text-decoration: none;
    cursor: pointer;

    /* типографика — label/md/medium с letter-spacing wide */
    font-family: var(--typography-label-font-family);
    font-weight: var(--typography-label-font-weight-medium);
    font-size: var(--typography-label-font-size-md);
    line-height: var(--typography-label-line-height-md);
    letter-spacing: var(--typography-label-letter-spacing-wide);

    /* цвета: только нейтральная шкала */
    color: var(--color-action-foreground-base-default);

    /* плавность переходов между состояниями */
    transition: color 120ms ease;
  }

  /* Focus ring — доступность.
     Figma: рамка inset 0 (вплотную к контенту), радиус xs */
  .nav-item:focus-visible {
    outline: 2px solid var(--color-action-outline-focus);
    outline-offset: 0;
    border-radius: var(--radius-xs);
  }

  /* Hover — только для активных ссылок */
  .nav-item:hover:not([aria-disabled='true']) {
    color: var(--color-action-foreground-base-hover);
  }

  /* Press — момент нажатия */
  .nav-item:active:not([aria-disabled='true']) {
    color: var(--color-action-foreground-base-press);
  }

  /* Disabled — эмулируем через aria-disabled
     (у <a> нет нативного :disabled псевдокласса) */
  .nav-item[aria-disabled='true'] {
    color: var(--color-action-foreground-base-disabled);
    cursor: not-allowed;
    pointer-events: none; /* блокируем клик */
  }
</style>
