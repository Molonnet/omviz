---
/* =============================================================
   MobileMenu — drop-down панель с навигацией для мобилы.
   Источник: Figma node 1419:7011 ("HeaderMobileDrawerMenuActive").

   Открытие: клик по любому [data-mobile-menu-open]
   Закрытие: клик по [data-mobile-menu-close], ESC, клик по ссылке,
             клик по backdrop-у (зона ниже панели)

   Поведение:
   - position: fixed, inset 0 — overlay-контейнер на весь экран
   - сам визуальный «meню» = topbar + divider + navbar-панель
     (rounded bottom 12px). Под панелью — backdrop-зона:
     прозрачная (просвечивает страница), но кликабельная — закрывает
   - z-index ниже ContactModal: «Let's connect» внутри меню
     открывает ContactModal и одновременно схлопывает само меню
   - body scroll lock пока меню открыто
   - aria-modal + role="dialog" + aria-labelledby
   - focus уходит на close-кнопку при открытии (a11y MVP)

   Layout (по Figma):
   ┌─ TopBar 60h (logo + close ButtonIcon) — повторяет HeaderMobile
   │   ── divider 1px ──
   ├─ Navbar-панель (pl=108, pr=16, py=20, gap=12, rounded-b 12)
   │     • About me / Archviz / Product Viz / Resume
   │     • Let’s connect (accent-color, chat-icon) — открывает ContactModal
   └─ backdrop (остаток экрана, клик = close)
   ============================================================= */

import Logo from './Logo.astro';
import ButtonIcon from './ui/ButtonIcon.astro';
import Icon from './ui/Icon.astro';
import { navLinks } from '../data/navLinks';
---

<div
  class="mobile-menu"
  data-mobile-menu
  role="dialog"
  aria-modal="true"
  aria-labelledby="mobile-menu-title"
  aria-hidden="true"
  hidden
>
  {/* Скрытый h1 для aria-labelledby — не дублируем визуально
      (логотип сам по себе — заголовок страницы). */}
  <h1 id="mobile-menu-title" class="visually-hidden">Site navigation</h1>

  <div class="mobile-menu__topbar">
    <div class="mobile-menu__logo-slot">
      <Logo />
    </div>
    <ButtonIcon
      appearance="secondary"
      size="md"
      aria-label="Close menu"
      data-mobile-menu-close
    >
      <Icon name="close" />
    </ButtonIcon>
  </div>
  <hr class="mobile-menu__divider" />

  <nav class="mobile-menu__nav" aria-label="Mobile main">
    <ul class="mobile-menu__list">
      {navLinks.map((link) => (
        <li class="mobile-menu__item">
          <a
            class="mobile-menu__link"
            href={link.href}
            data-mobile-menu-link
          >
            {link.label}
            {link.icon === 'chevron-down' && <Icon name="chevron-down" />}
          </a>
        </li>
      ))}
      {/* «Let's connect» — последний пункт списка, визуально как
          nav-link, но primary-цвет + chat-иконка. data-contact-open
          открывает ContactModal; listener ниже (см. <script>)
          параллельно схлопывает само меню, чтобы не громоздилось
          два оверлея. По Figma «Let's connect» = NavLink variant,
          не отдельный Button, поэтому делаем именно <a> в <li>. */}
      <li class="mobile-menu__item">
        <a
          class="mobile-menu__link mobile-menu__link--primary"
          href="#contact"
          data-contact-open
        >
          Let’s connect
          <Icon name="chat-conversation-circle" />
        </a>
      </li>
    </ul>
  </nav>

  {/* Backdrop — кликабельная зона ниже navbar-панели.
      По Figma панель не fullscreen, под ней просвечивает страница.
      Backdrop остаётся прозрачным, но ловит клик → close (UX:
      пользователь промахнулся мимо панели = хочет закрыть). */}
  <div class="mobile-menu__backdrop" data-mobile-menu-backdrop></div>
</div>

<script>
  /* ===========================================================
     MobileMenu — open/close + a11y
     ----------------------------------------------------------- */

  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  if (menu) {
    /* Запоминаем последний focused-элемент перед открытием — чтобы
       вернуть фокус туда же при закрытии (a11y best practice). */
    let lastFocused: HTMLElement | null = null;

    const open = () => {
      if (!menu.hidden) return;
      lastFocused = document.activeElement as HTMLElement | null;
      menu.hidden = false;
      menu.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      /* Фокус на close — самый ожидаемый выход. */
      const closeBtn = menu.querySelector<HTMLElement>('[data-mobile-menu-close]');
      closeBtn?.focus();
    };

    const close = () => {
      if (menu.hidden) return;
      menu.hidden = true;
      menu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lastFocused?.focus();
    };

    /* Делегаты — слушаем весь документ, а не сами кнопки. Так
       можно поставить [data-mobile-menu-open] в любое место на
       странице (не только в HeaderMobile) без повторной подписки. */
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('[data-mobile-menu-open]')) {
        e.preventDefault();
        open();
        return;
      }
      if (target.closest('[data-mobile-menu-close]')) {
        e.preventDefault();
        close();
        return;
      }
      /* Клик по backdrop-зоне (под navbar-панелью) — закрыть.
         data-mobile-menu-backdrop стоит только на нижней зоне,
         поэтому клик по самой панели или topbar сюда не попадает. */
      if (target.closest('[data-mobile-menu-backdrop]')) {
        close();
        return;
      }
      /* Клик по ссылке внутри меню — закрываем меню (юзер ушёл к
         якорю/странице, оверлей больше не нужен). */
      if (target.closest('[data-mobile-menu-link]')) {
        close();
        return;
      }
      /* Клик по "Let's connect" внутри меню — открывается ContactModal,
         и одновременно закрываем меню, чтобы не громоздилось два слоя
         оверлеев. Listener ContactModal обработает data-contact-open
         отдельно — порядок listeners не имеет значения, обе модалки
         знают только про свой trigger. */
      if (target.closest('[data-contact-open]') && menu.contains(target)) {
        close();
        return;
      }
    });

    /* ESC — закрыть. */
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.hidden) close();
    });

    /* Безопасность: если viewport вырос выше 1024 (поворот планшета,
       resize), меню больше не имеет смысла — закрываем, чтобы не
       висел оверлей с разблокированной прокруткой под ним. */
    const mq = window.matchMedia('(min-width: 1024px)');
    mq.addEventListener('change', (ev) => {
      if (ev.matches) close();
    });
  }
</script>

<style>
  /* ============== ROOT (overlay) ============== */
  /* ВАЖНО про HTML-атрибут hidden:
     user-agent style для [hidden] = display:none, но у нас .mobile-menu
     задаёт display:flex — специфичность класса (0,1,0) выше дефолта,
     поэтому браузерное скрытие НЕ срабатывает. Нужно явно сказать:
     .mobile-menu[hidden] { display:none } — специфичность класса+атрибута
     (0,2,0) перебивает .mobile-menu, и hidden снова работает.
     Без этого правила меню видно всегда, а скрипт молча тоглит атрибут
     без визуального эффекта (это и был баг с не-реагирующим крестиком). */
  .mobile-menu[hidden] {
    display: none;
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    /* z-index — выше BackToTop и контента, но НИЖЕ ContactModal,
       чтобы клик по "Let's connect" внутри меню показал модалку
       поверх. ContactModal по проекту использует z >= 100. */
    z-index: 50;
    /* Root прозрачный — фон есть только у topbar и navbar-панели,
       backdrop-зона пропускает страницу под собой (см. .mobile-menu__backdrop).
       Это даёт визуальный эффект «панель, висящая сверху», как в Figma. */
    background: transparent;
    display: flex;
    flex-direction: column;
    /* Меню никогда не нужно на десктопе — даже если кто-то снимет
       hidden руками. Двойная защита: hidden-атрибут + media query. */
  }
  @media (min-width: 1024px) {
    .mobile-menu {
      display: none !important;
    }
  }

  /* ============== TOPBAR ==============
     Симметрично HeaderMobile: те же 60h / px=16 / divider — чтобы
     при открытии меню юзер не видел «прыжка» хедера. */
  .mobile-menu__topbar {
    height: 60px;
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    padding: 0 var(--gap-md);
    flex-shrink: 0;
    background: var(--color-surface-base);
  }
  .mobile-menu__logo-slot {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    align-items: center;
  }
  .mobile-menu__divider {
    border: none;
    height: 1px;
    background: var(--color-content-border-muted);
    margin: 0;
  }

  /* ============== NAV (panel) ==============
     По Figma — компактная панель, выровненная вправо:
     - pl=108px (большой левый паддинг создаёт право-выравнивание),
     - pr=16px, py=20px,
     - gap=12px между пунктами,
     - rounded-b 12px — нижние углы скруглены, верх продолжает
       линию divider-а ровно.
     Сама панель не растягивается на всю высоту — flex-shrink: 0
     держит её natural-высоту, остаток flex-колонки отдаёт backdrop-у. */
  .mobile-menu__nav {
    flex-shrink: 0;
    background: var(--color-surface-base);
    padding: var(--gap-lg) var(--gap-md) var(--gap-lg) 108px;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
    /* position+z-index — обязательны, чтобы panel рисовался ПОВЕРХ
       backdrop-а. Backdrop ниже заезжает на 12px (margin-top: -12px)
       под нижний край панели — это даёт тёмному фону проявляться
       через вырезы скруглений. Без z-index порядок paint = порядок
       в DOM, и backdrop накрыл бы скругление сверху. */
    position: relative;
    z-index: 1;
  }
  .mobile-menu__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--gap-sm);                      /* 12px между пунктами */
  }
  .mobile-menu__item {
    display: flex;                           /* item-обёртка не блочит alignment */
  }
  .mobile-menu__link {
    /* Типографика — label/md/medium (как nav на десктопе),
       плюс капитализация — design system rule для nav-links.
       Padding по Figma: pr=12 py=8 (gap-2xs справа отделяет
       иконку, если она есть). */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--gap-2xs);
    padding: var(--padding-md) var(--padding-lg) var(--padding-md) 0;
    font-family: var(--typography-label-font-family);
    font-weight: var(--typography-label-font-weight-medium);
    font-size: var(--typography-label-font-size-md);
    line-height: var(--typography-label-line-height-md);
    letter-spacing: var(--typography-label-letter-spacing-wide);
    text-transform: capitalize;
    color: var(--color-action-foreground-secondary-default);
    text-decoration: none;
    transition: color 120ms ease;
  }
  .mobile-menu__link:hover,
  .mobile-menu__link:focus-visible {
    color: var(--color-action-foreground-secondary-hover);
  }
  .mobile-menu__link:focus-visible {
    outline: 2px solid var(--color-focus-ring-default);
    outline-offset: 2px;
    border-radius: var(--radius-xs);
  }
  /* «Let's connect» — primary-вариант nav-link.
     Цвет берётся из той же primary-палитры, что и Button.primary
     (см. Hero "See portfolio" / Footer "Let's connect"). */
  .mobile-menu__link--primary {
    color: var(--color-action-foreground-primary-default);
  }
  .mobile-menu__link--primary:hover,
  .mobile-menu__link--primary:focus-visible {
    color: var(--color-action-foreground-primary-hover);
  }

  /* ============== BACKDROP ==============
     Тёмная полупрозрачная зона ниже navbar-панели. Растягивается
     на весь остаток flex-колонки (flex: 1) — занимает место от
     низа панели до низа экрана. Тёмный фон визуально диммит
     страницу и фокусирует внимание на меню сверху.
     Цвет — surface/overlay (rgba(26,26,26,0.8)), тот же что
     у overlay-а ContactModal — для консистентности.
     pointer-events ловит клик → close. */
  .mobile-menu__backdrop {
    flex: 1 0 auto;
    background: var(--color-surface-overlay);
    cursor: pointer;
    /* Заезжает на 12px под низ navbar-панели, чтобы тёмный фон
       проявлялся через вырезы border-radius (без этого скругления
       «обрезаются» прозрачным фоном страницы и визуально не видны). */
    margin-top: -12px;
  }

  /* ============== A11Y HELPER ============== */
  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }
</style>
