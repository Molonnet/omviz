---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import NavLink from '../components/ui/NavLink.astro';
import Tab from '../components/ui/Tab.astro';
import Link from '../components/ui/Link.astro';

/* ─── DATA DEFINITIONS ────────────────────────────────────────────
   Здесь только перечисление имён токенов.
   Сами значения берутся из CSS через var() — никакого дублирования.
   ─────────────────────────────────────────────────────────────── */

// L1 цветовые рампы
const colorRamps = [
  { name: 'neutral', shades: ['50','100','200','300','400','500','600','700','800','900','950'] },
  { name: 'brand',   shades: ['50','100','200','300','400','500','600','700','800','900'] },
  { name: 'red',     shades: ['50','100','200','300','400','500','600','700','800','900'] },
  { name: 'green',   shades: ['50','100','200','300','400','500','600','700','800','900'] },
  { name: 'blue',    shades: ['50','100','200','300','400','500','600','700','800','900'] },
];

// L2 семантические группы цветов
const semanticColorGroups = [
  {
    title: 'content',
    description: 'Статические тексты, иконки, бордеры контента.',
    tokens: [
      { name: '--color-content-foreground-muted',      ref: 'neutral 600' },
      { name: '--color-content-foreground-base',       ref: 'neutral 800' },
      { name: '--color-content-foreground-base-error', ref: 'red 500' },
      { name: '--color-content-foreground-strong',     ref: 'neutral 950' },
      { name: '--color-content-foreground-accent',     ref: 'brand 600' },
      { name: '--color-content-border-muted',          ref: 'neutral 600' },
      { name: '--color-content-border-base',           ref: 'neutral 900' },
      { name: '--color-content-border-accent',         ref: 'brand 600' },
    ],
  },
  {
    title: 'action',
    description: 'Интерактив: кнопки, ссылки. Состояния default / hover / press / disabled.',
    tokens: [
      { name: '--color-action-foreground-secondary-default',     ref: 'neutral 800' },
      { name: '--color-action-foreground-secondary-hover',       ref: 'brand 500' },
      { name: '--color-action-foreground-secondary-press',       ref: 'brand 700' },
      { name: '--color-action-foreground-secondary-disabled',    ref: 'neutral 500' },
      { name: '--color-action-foreground-primary-default',   ref: 'brand 500' },
      { name: '--color-action-foreground-primary-hover',     ref: 'brand 700' },
      { name: '--color-action-foreground-primary-press',     ref: 'brand 800' },
      { name: '--color-action-foreground-primary-disabled',  ref: 'neutral 500' },
    ],
  },
  {
    title: 'navigation',
    description: 'Навигационные ссылки. global — общая навигация сайта (NavLink: Header md, Footer/breadcrumbs sm), local — табы внутри страницы (Tab). Состояния default / hover / press / current / disabled.',
    tokens: [
      { name: '--color-navigation-foreground-global-default',  ref: 'neutral 800' },
      { name: '--color-navigation-foreground-global-hover',    ref: 'brand 500' },
      { name: '--color-navigation-foreground-global-press',    ref: 'brand 700' },
      { name: '--color-navigation-foreground-global-current',  ref: 'brand 500' },
      { name: '--color-navigation-foreground-global-disabled', ref: 'neutral 500' },
      { name: '--color-navigation-foreground-local-default',   ref: 'neutral 600' },
      { name: '--color-navigation-foreground-local-hover',     ref: 'brand 500' },
      { name: '--color-navigation-foreground-local-press',     ref: 'brand 700' },
      { name: '--color-navigation-foreground-local-current',   ref: 'brand 500' },
      { name: '--color-navigation-foreground-local-disabled',  ref: 'neutral 500' },
    ],
  },
  {
    title: 'link',
    description: 'Текстовые ссылки внутри контента (Link). Состояния default / hover / press / visited / disabled.',
    tokens: [
      { name: '--color-link-default',  ref: 'neutral 800' },
      { name: '--color-link-hover',    ref: 'neutral 900' },
      { name: '--color-link-press',    ref: 'neutral 950' },
      { name: '--color-link-visited',  ref: 'neutral 700' },
      { name: '--color-link-disabled', ref: 'neutral 500' },
    ],
  },
  {
    title: 'focus',
    description: 'Кольцо фокуса для интерактивных элементов (клавиатурный tab).',
    tokens: [
      { name: '--color-focus-ring-default',                 ref: 'brand 500' },
    ],
  },
  {
    title: 'feedback',
    description: 'Статусные сообщения и валидация форм.',
    tokens: [
      { name: '--color-feedback-foreground-error',   ref: 'red 500' },
      { name: '--color-feedback-foreground-success', ref: 'green 500' },
      { name: '--color-feedback-foreground-info',    ref: 'blue 500' },
      { name: '--color-feedback-background-error',   ref: 'red 200' },
      { name: '--color-feedback-background-success', ref: 'green 200' },
      { name: '--color-feedback-background-info',    ref: 'blue 100' },
    ],
  },
  {
    title: 'surface',
    description: 'Фоны полотен, карточек, оверлеи.',
    tokens: [
      { name: '--color-surface-base',    ref: 'neutral 50' },
      { name: '--color-surface-accent',  ref: 'brand 100' },
      { name: '--color-surface-overlay', ref: 'neutral 950 @ 80%' },
    ],
  },
  {
    title: 'form',
    description: 'Поля ввода: фоны, бордеры, состояния.',
    tokens: [
      { name: '--color-form-foreground-base',          ref: 'neutral 900' },
      { name: '--color-form-foreground-accent',        ref: 'brand 500' },
      { name: '--color-form-background-base-default',  ref: 'neutral 50' },
      { name: '--color-form-background-base-hover',    ref: 'neutral 100' },
      { name: '--color-form-background-base-focus',    ref: 'neutral 200' },
      { name: '--color-form-background-base-error',    ref: 'red 50' },
      { name: '--color-form-background-base-disabled', ref: 'neutral 100' },
      { name: '--color-form-border-base-default',      ref: 'transparent' },
      { name: '--color-form-border-base-hover',        ref: 'neutral 200' },
      { name: '--color-form-border-base-error',        ref: 'red 500' },
      { name: '--color-form-border-accent-focus',      ref: 'brand 500' },
    ],
  },
];

// L2 типографические стили
type TypographyVariant = { label: string; className: string; sample: string };
type TypographyRole = { name: string; description: string; variants: TypographyVariant[] };

const typography: TypographyRole[] = [
  {
    name: 'display',
    description: 'Самый крупный — герой страницы. Anybody Medium 118/108. Один вариант.',
    variants: [{ label: 'display', className: 'sample-display', sample: 'Display' }],
  },
  {
    name: 'heading',
    description: 'Заголовок секции. Anybody Medium 60/70. Один вариант.',
    variants: [{ label: 'heading', className: 'sample-heading', sample: 'Heading' }],
  },
  {
    name: 'lead',
    description: 'Лид/подзаголовок Hero. Anybody Medium 36/36 +0.5 ls. Один flat-вариант (синхронизация 2026-05-18). Mobile mode: 18/18.',
    variants: [
      { label: 'lead', className: 'sample-lead', sample: 'Lead — full-cycle design expertise' },
    ],
  },
  {
    name: 'title',
    description: 'Заголовок карточки/блока. Roboto Medium 18/20. Один вариант.',
    variants: [{ label: 'title', className: 'sample-title', sample: 'Title' }],
  },
  {
    name: 'body',
    description: 'Основной текст. Roboto 16/20. Варианты по weight + letter-spacing.',
    variants: [
      { label: 'body / medium / tight',  className: 'sample-body-medium-tight',  sample: 'Body Medium Tight — Lorem ipsum dolor sit amet.' },
      { label: 'body / medium / snug',   className: 'sample-body-medium-snug',   sample: 'Body Medium Snug — Lorem ipsum dolor sit amet.' },
      { label: 'body / regular / tight', className: 'sample-body-regular-tight', sample: 'Body Regular Tight — Lorem ipsum dolor sit amet.' },
      { label: 'body / regular / snug',  className: 'sample-body-regular-snug',  sample: 'Body Regular Snug — Lorem ipsum dolor sit amet.' },
    ],
  },
  {
    name: 'label',
    description: 'Подписи к UI: кнопки, бейджи, теги. Полная матрица weight × size × ls.',
    variants: [
      { label: 'label / medium / md',  className: 'sample-label-medium-md',  sample: 'Label Medium MD' },
      { label: 'label / medium / sm',  className: 'sample-label-medium-sm',  sample: 'Label Medium SM' },
      { label: 'label / regular / xs', className: 'sample-label-regular-xs', sample: 'Label Regular XS' },
      { label: 'label / regular / 2xs',className: 'sample-label-regular-2xs',sample: 'Label Regular 2XS' },
      { label: 'label / regular / 3xs',className: 'sample-label-regular-3xs',sample: 'Label Regular 3XS' },
    ],
  },
  {
    name: 'caption',
    description: 'Мелкий вспомогательный текст. Roboto Regular 14/16. Один вариант.',
    variants: [{ label: 'caption', className: 'sample-caption', sample: 'Caption — small helper text' }],
  },
];

// L2 шкалы
const paddingTokens = [
  { token: '--padding-none', label: 'none' },
  { token: '--padding-sm',   label: 'sm' },
  { token: '--padding-md',   label: 'md' },
  { token: '--padding-lg',   label: 'lg' },
  { token: '--padding-xl',   label: 'xl' },
];

const gapTokens = [
  { token: '--gap-none', label: 'none' },
  { token: '--gap-2xs',  label: '2xs' },
  { token: '--gap-xs',   label: 'xs' },
  { token: '--gap-sm',   label: 'sm' },
  { token: '--gap-md',   label: 'md' },
  { token: '--gap-lg',   label: 'lg' },
  { token: '--gap-xl',   label: 'xl' },
  { token: '--gap-2xl',  label: '2xl' },
  { token: '--gap-3xl',  label: '3xl' },
  { token: '--gap-4xl',  label: '4xl' },
];

const radiusTokens = [
  { token: '--radius-none', label: 'none' },
  { token: '--radius-xs',   label: 'xs' },
  { token: '--radius-sm',   label: 'sm' },
  { token: '--radius-md',   label: 'md' },
];
---

<Layout title="Styleguide — Design Tokens">
  <main class="styleguide">
    <header class="page-header">
      <h1>Design System Styleguide</h1>
      <p class="page-meta">
        Live витрина токенов. Источник истины — Figma (фaйл Website Portfolio).
        Эта страница рендерится через CSS-переменные из <code>src/styles/tokens.css</code>.
      </p>
    </header>

    {/* ─── COLOR ─────────────────────────────────────────────── */}
    <section class="block">
      <h2>Color · L1 Primitives</h2>
      <p class="block-meta">
        Сырые рампы. Компоненты их <em>не используют</em> напрямую — только через L2 алиасы ниже.
      </p>

      {colorRamps.map(ramp => (
        <div class="ramp">
          <h3 class="ramp-name">{ramp.name}</h3>
          <div class="ramp-shades">
            {ramp.shades.map(shade => (
              <div class="swatch">
                <div
                  class="swatch-color"
                  style={`background: var(--_color-${ramp.name}-${shade});`}
                ></div>
                <div class="swatch-label">{shade}</div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="block">
      <h2>Color · L2 Semantic (Light)</h2>
      <p class="block-meta">
        Публичный API цветов для компонентов. Каждый токен — алиас на L1 рампу.
      </p>

      {semanticColorGroups.map(group => (
        <div class="semantic-group">
          <h3 class="semantic-group-title">{group.title}</h3>
          <p class="semantic-group-desc">{group.description}</p>
          <ul class="semantic-list">
            {group.tokens.map(t => (
              <li class="semantic-row">
                <span class="semantic-chip" style={`background: var(${t.name});`}></span>
                <code class="semantic-name">{t.name}</code>
                <span class="semantic-ref">{t.ref}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    {/* ─── TYPOGRAPHY ─────────────────────────────────────────── */}
    <section class="block">
      <h2>Typography</h2>
      <p class="block-meta">
        Семь ролей с гибридной глубиной: одни плоские (display, heading, title, caption),
        другие с вариантами (lead, body, label).
      </p>

      {typography.map(role => (
        <div class="typo-role">
          <h3 class="typo-role-name">{role.name}</h3>
          <p class="typo-role-desc">{role.description}</p>
          <div class="typo-samples">
            {role.variants.map(v => (
              <div class="typo-sample-row">
                <code class="typo-variant-label">{v.label}</code>
                <div class={`typo-sample ${v.className}`}>{v.sample}</div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    {/* ─── SCALE ──────────────────────────────────────────────── */}
    <section class="block">
      <h2>Scale</h2>
      <p class="block-meta">
        Единая числовая шкала для spacing/gap/padding/radius — все ступени кратны 4
        (плюс 2px для тонких бордеров, если когда-нибудь понадобится).
      </p>

      <div class="scale-block">
        <h3>padding</h3>
        <div class="scale-rows">
          {paddingTokens.map(t => (
            <div class="scale-row">
              <code class="scale-label">{t.label}</code>
              <div class="scale-bar" style={`width: var(${t.token});`}></div>
              <span class="scale-value" style={`--v: var(${t.token});`}></span>
            </div>
          ))}
        </div>
      </div>

      <div class="scale-block">
        <h3>gap</h3>
        <div class="scale-rows">
          {gapTokens.map(t => (
            <div class="scale-row">
              <code class="scale-label">{t.label}</code>
              <div class="scale-bar" style={`width: var(${t.token});`}></div>
              <span class="scale-value" style={`--v: var(${t.token});`}></span>
            </div>
          ))}
        </div>
      </div>

      <div class="scale-block">
        <h3>radius</h3>
        <div class="radius-row">
          {radiusTokens.map(t => (
            <div class="radius-card">
              <div class="radius-shape" style={`border-radius: var(${t.token});`}></div>
              <code class="radius-label">{t.label}</code>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ─── COMPONENTS ─────────────────────────────────────────── */}
    <section class="block">
      <h2>Components</h2>
      <p class="block-meta">
        Дизайн-системные примитивы. Используют только L2 токены.
      </p>

      <div class="component-card">
        <h3 class="component-name">Button</h3>
        <p class="component-meta">
          Figma: <code>node 262:1806</code> · 2 appearance × 4 state = 8 вариантов.
          Text-only стиль (без фона/бордера).
        </p>

        {/* Матрица — для прямого сравнения с Figma */}
        <div class="btn-matrix">
          <div class="btn-matrix-corner"></div>
          <div class="btn-matrix-header">Default</div>
          <div class="btn-matrix-header">Hover</div>
          <div class="btn-matrix-header">Press</div>
          <div class="btn-matrix-header">Disabled</div>

          <div class="btn-matrix-row-label">Primary</div>
          <div class="btn-matrix-cell">
            <Button appearance="primary">Label <span class="icon-stub" /></Button>
          </div>
          <div class="btn-matrix-cell force-hover">
            <Button appearance="primary">Label <span class="icon-stub" /></Button>
          </div>
          <div class="btn-matrix-cell force-press">
            <Button appearance="primary">Label <span class="icon-stub" /></Button>
          </div>
          <div class="btn-matrix-cell">
            <Button appearance="primary" disabled>Label <span class="icon-stub" /></Button>
          </div>

          <div class="btn-matrix-row-label">Secondary</div>
          <div class="btn-matrix-cell">
            <Button appearance="secondary">Label <span class="icon-stub" /></Button>
          </div>
          <div class="btn-matrix-cell force-hover">
            <Button appearance="secondary">Label <span class="icon-stub" /></Button>
          </div>
          <div class="btn-matrix-cell force-press">
            <Button appearance="secondary">Label <span class="icon-stub" /></Button>
          </div>
          <div class="btn-matrix-cell">
            <Button appearance="secondary" disabled>Label <span class="icon-stub" /></Button>
          </div>
        </div>

        <p class="component-note">
          Hover и Press — реально интерактивные на кнопках в колонке "Default".
          В колонках "Hover" и "Press" состояния <em>принудительно</em>
          подменены через локальный CSS витрины — для сравнения с Figma матрицей
          одним взглядом.
        </p>
      </div>

      {/* ─── NavLink ─────────────────────────────────────────── */}
      <div class="component-card">
        <h3 class="component-name">NavLink</h3>
        <p class="component-meta">
          Figma: <code>node 198:1313</code> · 2 size × 5 state = 10 вариантов.
          HTML-семантика: <code>&lt;a&gt;</code> (ссылка), не <code>&lt;button&gt;</code>.
          Используется для любой НАВИГАЦИИ — Header navbar (md),
          Footer-колонка, breadcrumbs, sidebar (sm). В отличие от Link
          у NavLink нет <code>:visited</code> (для навигации не имеет смысла),
          но есть <code>current</code> — где пользователь сейчас находится.
          Токены: <code>navigation.foreground.global.*</code>
        </p>

        <div class="nav-matrix nav-matrix--5col nav-matrix--with-rowlabel">
          <div class="nav-matrix-rowlabel"></div>
          <div class="nav-matrix-header">Default</div>
          <div class="nav-matrix-header">Hover</div>
          <div class="nav-matrix-header">Press</div>
          <div class="nav-matrix-header">Current</div>
          <div class="nav-matrix-header">Disabled</div>

          {/* Row 1: md — Header navbar (18/24) */}
          <div class="nav-matrix-rowlabel">md</div>
          <div class="nav-matrix-cell">
            <NavLink href="#">Label <span class="icon-stub" /></NavLink>
          </div>
          <div class="nav-matrix-cell force-nav-hover">
            <NavLink href="#">Label <span class="icon-stub" /></NavLink>
          </div>
          <div class="nav-matrix-cell force-nav-press">
            <NavLink href="#">Label <span class="icon-stub" /></NavLink>
          </div>
          <div class="nav-matrix-cell">
            <NavLink href="#" current>Label <span class="icon-stub" /></NavLink>
          </div>
          <div class="nav-matrix-cell">
            <NavLink href="#" disabled>Label <span class="icon-stub" /></NavLink>
          </div>

          {/* Row 2: sm — Footer / breadcrumbs / sidebar (15/18 capitalize) */}
          <div class="nav-matrix-rowlabel">sm</div>
          <div class="nav-matrix-cell">
            <NavLink href="#" size="sm">label</NavLink>
          </div>
          <div class="nav-matrix-cell force-nav-hover">
            <NavLink href="#" size="sm">label</NavLink>
          </div>
          <div class="nav-matrix-cell force-nav-press">
            <NavLink href="#" size="sm">label</NavLink>
          </div>
          <div class="nav-matrix-cell">
            <NavLink href="#" size="sm" current>label</NavLink>
          </div>
          <div class="nav-matrix-cell">
            <NavLink href="#" size="sm" disabled>label</NavLink>
          </div>
        </div>

        <p class="component-note">
          Default-ячейки интерактивны: наведи курсор/нажми, чтобы увидеть реальные
          hover и press. В остальных колонках состояния симулированы через CSS
          витрины — как в матрице Button.
        </p>
      </div>

      {/* ─── Tab ─────────────────────────────────────────────── */}
      <div class="component-card">
        <h3 class="component-name">Tab</h3>
        <p class="component-meta">
          Figma: <code>node 913:1219</code> · 1 appearance × 5 state = 5 вариантов.
          HTML-семантика: <code>&lt;button&gt;</code> — локальный переключатель
          секций внутри страницы (фильтры, табы). Отличие от NavLink —
          цвета <code>navigation.foreground.local.*</code> (светлее, чтобы header
          оставался главным по иерархии) и нет горизонтального padding.
        </p>

        <div class="nav-matrix nav-matrix--5col">
          <div class="nav-matrix-header">Default</div>
          <div class="nav-matrix-header">Hover</div>
          <div class="nav-matrix-header">Press</div>
          <div class="nav-matrix-header">Current</div>
          <div class="nav-matrix-header">Disabled</div>

          <div class="nav-matrix-cell">
            <Tab>Label <span class="icon-stub" /></Tab>
          </div>
          <div class="nav-matrix-cell force-tab-hover">
            <Tab>Label <span class="icon-stub" /></Tab>
          </div>
          <div class="nav-matrix-cell force-tab-press">
            <Tab>Label <span class="icon-stub" /></Tab>
          </div>
          <div class="nav-matrix-cell">
            <Tab current>Label <span class="icon-stub" /></Tab>
          </div>
          <div class="nav-matrix-cell">
            <Tab disabled>Label <span class="icon-stub" /></Tab>
          </div>
        </div>

        <p class="component-note">
          Default-ячейка интерактивна: наведи курсор/нажми, чтобы увидеть реальные
          hover и press. Current и Disabled — реальные состояния через props.
        </p>
      </div>

      {/* ─── Link ────────────────────────────────────────────── */}
      <div class="component-card">
        <h3 class="component-name">Link</h3>
        <p class="component-meta">
          Figma: <code>node 284:895</code> · 2 size × 5 state = 10 вариантов.
          HTML-семантика: <code>&lt;a href&gt;</code> — текстовая ссылка
          с visited-стейтом. Токены <code>link.*</code> (отдельная группа).
          Размеры: <b>sm</b> — 15/18 capitalize (footer, политики),
          <b>xs</b> — 14/16 UPPERCASE (категории, метки).
        </p>

        <div class="link-matrix">
          {/* Header row */}
          <div class="link-matrix-size-label" aria-hidden="true"></div>
          <div class="nav-matrix-header">Default</div>
          <div class="nav-matrix-header">Hover</div>
          <div class="nav-matrix-header">Press</div>
          <div class="nav-matrix-header">Visited</div>
          <div class="nav-matrix-header">Disabled</div>

          {/* sm row */}
          <div class="link-matrix-size-label">sm</div>
          <div class="nav-matrix-cell">
            <Link href="#">label</Link>
          </div>
          <div class="nav-matrix-cell force-link-hover">
