    font-family: var(--typography-label-font-family);
    font-weight: var(--typography-label-font-weight-medium);
    font-size: var(--typography-label-font-size-3xs);
    color: var(--color-content-foreground-muted);
    text-transform: uppercase;
    letter-spacing: var(--_letter-spacing-04);
    text-align: center;
  }
  .nav-matrix-cell {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--padding-md);
    background: var(--color-surface-base);
    border-radius: var(--radius-xs);
  }

  /* Принудительные состояния NavLink — те же navigation.global.* цвета,
     что и в самом компоненте; дублирование намеренное (это витрина).
     :not([aria-current='page']) — на случай если в ячейке current-вариант
     (сейчас не так, но защищаемся на будущее). */
  .force-nav-hover :global(.nav-link:not([aria-current='page'])) {
    color: var(--color-navigation-foreground-global-hover);
  }
  .force-nav-press :global(.nav-link:not([aria-current='page'])) {
    color: var(--color-navigation-foreground-global-press);
  }

  /* Принудительные состояния Tab — navigation.local.* */
  .force-tab-hover :global(.tab:not([aria-current='true'])) {
    color: var(--color-navigation-foreground-local-hover);
  }
  .force-tab-press :global(.tab:not([aria-current='true'])) {
    color: var(--color-navigation-foreground-local-press);
  }

  /* ─── COMPONENTS · LINK ─────────────────────────────────────
     5 колонок: подпись размера + 4 state.
     2 строки контента: sm и xs. */
  .link-matrix {
    display: grid;
    grid-template-columns: auto repeat(5, 1fr);
    gap: var(--gap-sm);
    align-items: center;
  }
