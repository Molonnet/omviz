  .icon-stub {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 1.5px solid currentColor;
    border-radius: 50%;
    /* currentColor — наследует цвет текста кнопки в каждом состоянии */
  }

  /* ⚠ Принудительные состояния — ТОЛЬКО для витрины.
     Дублируют значения из Button.astro — если правишь там, правь и здесь.
     Используем :global для пробития scoped CSS Astro. */
  .force-hover :global(.btn--primary) {
    color: var(--color-action-foreground-primary-hover);
  }
  .force-press :global(.btn--primary) {
    color: var(--color-action-foreground-primary-press);
  }
  .force-hover :global(.btn--secondary) {
    color: var(--color-action-foreground-secondary-hover);
  }
  .force-press :global(.btn--secondary) {
    color: var(--color-action-foreground-secondary-press);
  }

  /* ─── COMPONENTS · NAV MATRIX (NavLink, Tab) ───────────────── */
  /* Матрица header-строка + строка с самим элементом */
  .nav-matrix {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--gap-sm);
    align-items: center;
  }
  /* Модификатор для NavLink/Tab — 5 колонок (+ current) */
  .nav-matrix--5col {
    grid-template-columns: repeat(5, 1fr);
  }
  /* Вариант с лейблом строки слева (для матрицы NavLink с двумя размерами:
     md / sm). Лейбл занимает узкую первую колонку, дальше — обычные 5
     ячеек состояний. */
  .nav-matrix--with-rowlabel {
    grid-template-columns: 40px repeat(5, 1fr);
  }
  .nav-matrix-rowlabel {
    font-family: var(--typography-label-font-family);
    font-weight: var(--typography-label-font-weight-medium);
    font-size: var(--typography-label-font-size-3xs);
